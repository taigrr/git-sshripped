    "git-sshripped": "bin/git-sshripped"
  },
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@git-sshripped/darwin-arm64": "0.1.3",
    "@git-sshripped/darwin-x64": "0.1.3",
    "@git-sshripped/linux-arm64": "0.1.3",
    "@git-sshripped/linux-x64": "0.1.3",
    "@git-sshripped/linux-x64-musl": "0.1.3",
    "@git-sshripped/win32-x64": "0.1.3"
